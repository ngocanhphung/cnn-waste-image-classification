    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M1: ANN Baseline в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   Treats each pixel as an independent input feature вҖ” no spatial awareness.\n",
        "#   A 96Г—96Г—3 image becomes a flat vector of 27,648 values fed directly into\n",
        "#   a Dense layer. This model cannot detect edges, textures, or shapes because\n",
        "#   it has no mechanism to relate neighbouring pixels. It serves as a lower-bound\n",
        "#   baseline: if even this model cannot learn anything, there is a data or\n",
        "#   preprocessing problem. Expected performance: near random chance (~17%).\n",
        "#   The gap between M1 and M2 motivates the use of convolutional layers.\n",
        "\n",
        "def build_m1():\n",
        "    model = Sequential([\n",
        "        Flatten(input_shape=(img_rows, img_cols, channels)),\n",
        "        Dense(128, activation='relu'),\n",
        "        Dense(num_classes, activation='softmax')\n",
        "    ], name='M1_ANN_Baseline')\n",
        "    model.summary()\n",
        "    return model\n",
        "\n",
        "m1 = build_m1()\n",
        "m1.compile(optimizer='adam',\n",
        "           loss='sparse_categorical_crossentropy',\n",
        "           metrics=['accuracy'])\n",
        "\n",
        "history_m1 = m1.fit(\n",
        "    datagen_light.flow(X_train, y_train, batch_size=BATCH_SIZE),\n",
        "    epochs=30,\n",
        "    validation_data=(X_test, y_test),\n",
        "    callbacks=get_callbacks(),\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "plot_history(history_m1, 'M1 вҖ” ANN Baseline')\n",
        "results_m1 = evaluate_model(m1, X_test, y_test, 'M1 вҖ” ANN Baseline')"
      ],
