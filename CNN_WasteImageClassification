    },
    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M5: BatchNorm CNN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   Identical to M3 but replaces dropout with BatchNormalization after each\n",
        "#   conv layer. BatchNorm normalises activations within each mini-batch,\n",
        "#   stabilising the distribution of inputs to each layer during training.\n",
        "#   This reduces internal covariate shift, allows higher learning rates, and\n",
        "#   acts as a mild regulariser by adding noise through batch statistics.\n",
        "#   Placement: after Conv, before activation (standard convention).\n",
        "#   Comparing M4 vs M5 directly answers: is dropout or BatchNorm more effective\n",
        "#   as a regulariser on this dataset and architecture?\n",
        "\n",
        "def build_m5():\n",
        "    model = Sequential([\n",
        "        # Block 1\n",
        "        Conv2D(32,  (3,3), padding='same',\n",
        "               input_shape=(img_rows, img_cols, channels)),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 2\n",
        "        Conv2D(64,  (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 3\n",
        "        Conv2D(128, (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        Flatten(),\n",
        "        Dense(256, activation='relu'),\n",
        "        Dense(num_classes, activation='softmax')\n",
        "    ], name='M5_BatchNorm_CNN')\n",
        "    model.summary()\n",
        "    return model\n",
        "\n",
        "m5 = build_m5()\n",
        "m5.compile(optimizer='adam',\n",
        "           loss='sparse_categorical_crossentropy',\n",
        "           metrics=['accuracy'])\n",
        "\n",
        "history_m5 = m5.fit(\n",
        "    datagen_light.flow(X_train, y_train, batch_size=BATCH_SIZE),\n",
        "    epochs=30,\n",
        "    validation_data=(X_test, y_test),\n",
        "    callbacks=get_callbacks(),\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "plot_history(history_m5, 'M5 вҖ” BatchNorm CNN')\n",
        "results_m5 = evaluate_model(m5, X_test, y_test, 'M5 вҖ” BatchNorm CNN')"
      ],
