      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M2: Tiny CNN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   Introduces a single convolutional block (Conv вҶ’ Pool) before the dense head.\n",
        "#   The 3Г—3 kernel slides across the image preserving spatial relationships\n",
        "#   between neighbouring pixels вҖ” the fundamental advantage of CNNs over ANNs\n",
        "#   for image data. 32 filters detect 32 distinct low-level features (edges,\n",
        "#   colour blobs). MaxPooling halves spatial dimensions, providing translation\n",
        "#   invariance: a cardboard edge detected slightly left or right still activates\n",
        "#   the same filter. Dropout(0.25) after pooling and Dropout(0.5) in the dense\n",
        "#   head provide early regularisation. No BatchNorm вҖ” deliberately absent to\n",
        "#   isolate the effect of adding it in M5.\n",
        "\n",
        "def build_m2():\n",
        "    model = Sequential([\n",
        "        Conv2D(32, (3,3), activation='relu', padding='same',\n",
        "               input_shape=(img_rows, img_cols, channels)),\n",
        "        MaxPooling2D(2, 2),\n",
        "        Flatten(),\n",
        "        Dense(128, activation='relu'),\n",
        "        Dense(num_classes, activation='softmax')\n",
        "    ], name='M2_Tiny_CNN')\n",
        "    model.summary()\n",
        "    return model\n",
        "\n",
        "m2 = build_m2()\n",
        "m2.compile(optimizer='adam',\n",
        "           loss='sparse_categorical_crossentropy',\n",
        "           metrics=['accuracy'])\n",
        "\n",
        "history_m2 = m2.fit(\n",
        "    datagen_light.flow(X_train, y_train, batch_size=BATCH_SIZE),\n",
        "    epochs=30,\n",
        "    validation_data=(X_test, y_test),\n",
        "    callbacks=get_callbacks(),\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "plot_history(history_m2, 'M2 вҖ” Tiny CNN')\n",
        "results_m2 = evaluate_model(m2, X_test, y_test, 'M2 вҖ” Tiny CNN')"
      ],
