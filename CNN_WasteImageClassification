    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M4: Dropout CNN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   Identical to M3 but adds dropout regularisation at two points:\n",
        "#   SpatialDropout2D(0.25) after each conv block drops entire feature maps\n",
        "#   rather than individual activations. This is more effective than standard\n",
        "#   dropout in conv layers because adjacent pixels in a feature map are highly\n",
        "#   correlated вҖ” zeroing a single pixel is easily compensated by neighbours,\n",
        "#   whereas zeroing an entire map forces the network to rely on other filters.\n",
        "#   Dropout(0.5) in the dense head prevents co-adaptation of learned features.\n",
        "#   Comparison with M3 isolates the effect of dropout alone.\n",
        "\n",
        "def build_m4():\n",
        "    model = Sequential([\n",
        "        # Block 1\n",
        "        Conv2D(32,  (3,3), activation='relu', padding='same',\n",
        "               input_shape=(img_rows, img_cols, channels)),\n",
        "        MaxPooling2D(2, 2),\n",
        "        SpatialDropout2D(0.25),\n",
        "\n",
        "        # Block 2\n",
        "        Conv2D(64,  (3,3), activation='relu', padding='same'),\n",
        "        MaxPooling2D(2, 2),\n",
        "        SpatialDropout2D(0.25),\n",
        "\n",
        "        # Block 3\n",
        "        Conv2D(128, (3,3), activation='relu', padding='same'),\n",
        "        MaxPooling2D(2, 2),\n",
        "        SpatialDropout2D(0.25),\n",
        "\n",
        "        Flatten(),\n",
        "        Dense(256, activation='relu'),\n",
        "        Dense(num_classes, activation='softmax')\n",
        "    ], name='M4_Dropout_CNN')\n",
        "    model.summary()\n",
        "    return model\n",
        "\n",
        "m4 = build_m4()\n",
        "m4.compile(optimizer='adam',\n",
        "           loss='sparse_categorical_crossentropy',\n",
        "           metrics=['accuracy'])\n",
        "\n",
        "history_m4 = m4.fit(\n",
        "    datagen_light.flow(X_train, y_train, batch_size=BATCH_SIZE),\n",
        "    epochs=30,\n",
        "    validation_data=(X_test, y_test),\n",
        "    callbacks=get_callbacks(),\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "plot_history(history_m4, 'M4 вҖ” Dropout CNN')\n",
        "results_m4 = evaluate_model(m4, X_test, y_test, 'M4 вҖ” Dropout CNN')"
      ],
