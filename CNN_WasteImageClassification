    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M7: Strong Augmentation CNN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   M6 (GAP head) underperformed M5 (Flatten head) on this dataset, suggesting\n",
        "#   the Flatten + Dense(256) head has sufficient capacity to learn the class\n",
        "#   boundaries without the spatial invariance trade-off that GAP introduces.\n",
        "#   M7 therefore returns to M5's exact architecture as the stronger baseline.\n",
        "#\n",
        "#   The only change from M5 is the augmentation policy: light (horizontal flip\n",
        "#   + 15В° rotation) is replaced with strong augmentation (flip + 20В° rotation\n",
        "#   + zoom Вұ20% + brightness jitter Вұ20% + small translations).\n",
        "#\n",
        "#   Rationale for stronger augmentation:\n",
        "#   With ~330 training images per class, the model is at high risk of memorising\n",
        "#   specific image compositions rather than learning class-defining features.\n",
        "#   Zoom simulates waste items photographed at different distances from the\n",
        "#   camera. Brightness jitter replicates variable lighting conditions in a\n",
        "#   recycling facility. Translations mimic off-centre framing. Together these\n",
        "#   synthetically expand the effective training distribution without collecting\n",
        "#   new data. Comparing M5 vs M7 isolates the effect of augmentation strength\n",
        "#   on M5's architecture.\n",
        "\n",
        "def build_m7():\n",
        "    model = Sequential([\n",
        "        # Block 1\n",
        "        Conv2D(32,  (3,3), padding='same',\n",
        "               input_shape=(img_rows, img_cols, channels)),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 2\n",
        "        Conv2D(64,  (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 3\n",
        "        Conv2D(128, (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        Flatten(),\n",
        "        Dense(256, activation='relu'),\n",
        "        Dense(num_classes, activation='softmax')\n",
        "    ], name='M7_StrongAug_CNN')\n",
        "    model.summary()\n",
        "    return model\n",
        "\n",
        "m7 = build_m7()\n",
        "\n",
        "m7.compile(optimizer='adam',\n",
        "           loss='sparse_categorical_crossentropy',\n",
        "           metrics=['accuracy'])\n",
        "\n",
        "# Uses datagen_strong вҖ” the only difference from M5\n",
        "history_m7 = m7.fit(\n",
        "    datagen_strong.flow(X_train, y_train, batch_size=BATCH_SIZE),\n",
        "    epochs=40,\n",
        "    validation_data=(X_test, y_test),\n",
        "    callbacks=get_callbacks(patience_es=12, patience_lr=6),\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "plot_history(history_m7, 'M7 вҖ” Strong Augmentation CNN')\n",
        "results_m7 = evaluate_model(m7, X_test, y_test, 'M7 вҖ” Strong Augmentation CNN')"
      ],
