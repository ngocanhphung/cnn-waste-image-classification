    {
      "cell_type": "code",
      "source": [
        "def get_callbacks(patience_es=10, patience_lr=5):\n",
        "    return [\n",
        "        EarlyStopping(monitor='val_loss', patience=patience_es,\n",
        "                      restore_best_weights=True, verbose=1),\n",
        "        ReduceLROnPlateau(monitor='val_loss', factor=0.5,\n",
        "                          patience=patience_lr, min_lr=1e-6, verbose=1)\n",
        "    ]\n",
        "\n",
        "def plot_history(history, model_name):\n",
        "    fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n",
        "    axes[0].plot(history.history['accuracy'],     label='Train')\n",
        "    axes[0].plot(history.history['val_accuracy'], label='Validation')\n",
        "    axes[0].set_title(f'{model_name} вҖ” Accuracy')\n",
        "    axes[0].set_xlabel('Epoch')\n",
        "    axes[0].legend()\n",
        "\n",
        "    axes[1].plot(history.history['loss'],     label='Train')\n",
        "    axes[1].plot(history.history['val_loss'], label='Validation')\n",
        "    axes[1].set_title(f'{model_name} вҖ” Loss')\n",
        "    axes[1].set_xlabel('Epoch')\n",
        "    axes[1].legend()\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "def evaluate_model(model, X, y_true, model_name):\n",
        "    loss, acc = model.evaluate(X, y_true, verbose=0)\n",
        "    y_pred = np.argmax(model.predict(X, verbose=0), axis=1)\n",
        "\n",
        "    print(f\"\\n{'='*60}\")\n",
        "    print(f\"  {model_name}\")\n",
        "    print(f\"  Test Accuracy : {acc:.4f}  |  Test Loss : {loss:.4f}\")\n",
        "    print('='*60)\n",
        "    print(classification_report(y_true, y_pred, target_names=CLASSES))\n",
        "\n",
        "    # Normalised confusion matrix\n",
        "    cm = confusion_matrix(y_true, y_pred, normalize='true')\n",
        "    plt.figure(figsize=(8, 6))\n",
        "    sns.heatmap(cm, annot=True, fmt='.2f', cmap='Blues',\n",
        "                xticklabels=CLASSES, yticklabels=CLASSES)\n",
        "    plt.title(f'{model_name} вҖ” Normalised Confusion Matrix')\n",
        "    plt.ylabel('True Label')\n",
        "    plt.xlabel('Predicted Label')\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    return {\n",
        "        'model'   : model_name,\n",
        "        'accuracy': acc,\n",
        "        'loss'    : loss,\n",
        "        'y_pred'  : y_pred,\n",
        "        'report'  : classification_report(y_true, y_pred,\n",
        "                                          target_names=CLASSES,\n",
        "                                          output_dict=True)\n",
        "    }"
      ],
      "metadata": {
        "id": "doiVs5CuHTcn"
      },
