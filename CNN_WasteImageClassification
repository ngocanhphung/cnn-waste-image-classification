        "## Load Images & Split"
      ],
      "metadata": {
        "id": "vHKHHeQeHHUU"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ Load all images into memory at 96Г—96 в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "X, y = [], []\n",
        "\n",
        "for idx, cls in enumerate(CLASSES):\n",
        "    cls_path = os.path.join(DATA_DIR, cls)\n",
        "    for fname in os.listdir(cls_path):\n",
        "        fpath = os.path.join(cls_path, fname)\n",
        "        try:\n",
        "            img = tf.keras.utils.load_img(\n",
        "                fpath, target_size=(img_rows, img_cols))\n",
        "            X.append(tf.keras.utils.img_to_array(img))\n",
        "            y.append(idx)\n",
        "        except Exception:\n",
        "            pass\n",
        "\n",
        "X = np.array(X, dtype='float32') / 255.0\n",
        "y = np.array(y)\n",
        "\n",
        "print(f\"X shape : {X.shape}\")\n",
        "print(f\"y shape : {y.shape}\")\n",
        "print(f\"Pixel range: [{X.min():.2f}, {X.max():.2f}]\")\n",
        "\n",
        "# в”Җв”Җ 70/30 stratified split в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=0.30, random_state=SEED, stratify=y\n",
        ")\n",
        "\n",
        "print(f\"\\nTraining samples : {len(X_train)}\")\n",
        "print(f\"Testing  samples : {len(X_test)}\")"
      ],
