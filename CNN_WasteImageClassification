    },
    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M6: GAP CNN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   Takes the best regulariser from M4/M5 (BatchNorm) and replaces Flatten\n",
        "#   with GlobalAveragePooling2D (GAP). After the final conv block, the feature\n",
        "#   map has shape (H, W, 128). Flatten unrolls this into HГ—WГ—128 values,\n",
        "#   creating a massive Dense connection sensitive to object position.\n",
        "#   GAP instead averages each of the 128 feature maps to a single scalar,\n",
        "#   producing a compact 128-d vector regardless of spatial size. Benefits:\n",
        "#   (1) dramatically fewer parameters вҖ” the Dense connection shrinks from\n",
        "#   HГ—WГ—128Г—256 to 128Г—128; (2) built-in spatial invariance вҖ” a glass bottle\n",
        "#   in the top-left vs bottom-right of the frame produces the same GAP output;\n",
        "#   (3) reduced overfitting on small datasets.\n",
        "\n",
        "def build_m6():\n",
        "    model = Sequential([\n",
        "        # Block 1\n",
        "        Conv2D(32,  (3,3), padding='same',\n",
        "               input_shape=(img_rows, img_cols, channels)),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 2\n",
        "        Conv2D(64,  (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 3\n",
