    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M9: MobileNetV2 вҖ” Feature Extraction (frozen backbone) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   Models M1вҖ“M8 learn visual features from scratch on ~2,000 training images.\n",
        "#   The fundamental limitation is data scarcity вҖ” ~330 images per class is\n",
        "#   insufficient to learn robust, generalisable feature detectors from random\n",
        "#   initialisation. Transfer learning addresses this directly.\n",
        "#\n",
        "#   MobileNetV2 was pretrained on ImageNet (1.2 million images, 1,000 classes).\n",
        "#   Its convolutional layers already encode rich, hierarchical visual features:\n",
        "#   edges and gradients in early layers, textures and object parts in later layers.\n",
        "#   These features transfer well to waste classification because both domains\n",
        "#   involve natural images with colour, texture, and shape cues.\n",
        "#\n",
        "#   In Phase 1 (M9), the entire MobileNetV2 backbone is frozen вҖ” only the new\n",
        "#   classification head is trained. This is the safest approach: pretrained\n",
        "#   features are preserved exactly, and the head quickly learns to map those\n",
        "#   features to our 6 waste classes. training=False on the base model keeps\n",
        "#   BatchNorm layers in inference mode (uses stored statistics rather than\n",
        "#   batch statistics), which is critical when the backbone is frozen.\n",
        "#\n",
        "#   MobileNetV2 is chosen over VGG16/ResNet50 because its depthwise separable\n",
        "#   convolutions are computationally lightweight вҖ” appropriate for potential\n",
        "#   deployment on edge hardware in a recycling facility, and faster to train\n",
        "#   on Colab's free-tier GPU.\n",
        "#\n",
        "#   Input preprocessing: MobileNetV2 expects pixels scaled to [-1, 1] via\n",
        "#   preprocess_input вҖ” NOT [0,1]. Using the wrong normalisation silently\n",
        "#   degrades accuracy because the pretrained weights were calibrated to [-1,1].\n",
        "print(\"Reloading images with correct MobileNetV2 preprocessing...\")\n",
        "X_tl, y_tl = [], []\n",
        "\n",
        "for idx, cls in enumerate(CLASSES):\n",
        "    cls_path = os.path.join(DATA_DIR, cls)\n",
        "    for fname in os.listdir(cls_path):\n",
        "        fpath = os.path.join(cls_path, fname)\n",
        "        try:\n",
        "            img = tf.keras.utils.load_img(fpath, target_size=(96, 96))\n",
        "            arr = tf.keras.utils.img_to_array(img)  # raw [0, 255] вҖ” NO /255\n",
        "            X_tl.append(arr)\n",
        "            y_tl.append(idx)\n",
        "        except Exception:\n",
        "            pass\n",
        "\n",
        "# preprocess_input handles the [-1, 1] scaling internally\n",
        "X_tl = tf.keras.applications.mobilenet_v2.preprocess_input(\n",
        "    np.array(X_tl, dtype='float32')\n",
        ")\n",
        "y_tl = np.array(y_tl)\n",
        "\n",
        "print(f\"Pixel range after preprocessing: [{X_tl.min():.2f}, {X_tl.max():.2f}]\")\n",
        "# Should print approximately [-1.00, 1.00]\n",
        "\n",
        "X_train_tl, X_test_tl, y_train_tl, y_test_tl = train_test_split(\n",
        "    X_tl, y_tl, test_size=0.30, random_state=SEED, stratify=y_tl\n",
        ")\n",
        "\n",
        "datagen_tl = ImageDataGenerator(\n",
        "    horizontal_flip=True,\n",
        "    rotation_range=15\n",
        ")\n",
        "datagen_tl.fit(X_train_tl)\n",
        "\n",
        "print(f\"TL train: {len(X_train_tl)}  |  TL test: {len(X_test_tl)}\")"
