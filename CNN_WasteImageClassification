        "## M8 - CNN (x2 layer/block - VGG Style)"
      ],
      "metadata": {
        "id": "iLYvI48bRUp6"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# в”Җв”Җ M8: Deep VGG-style CNN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n",
        "# Architecture rationale:\n",
        "#   M7 (strong augmentation) collapsed to ~19% accuracy вҖ” the aggressive zoom,\n",
        "#   brightness jitter and translations distorted images beyond the point where\n",
        "#   class-defining features remain recognisable at 96Г—96. This confirms that\n",
        "#   light augmentation (M5) is the correct policy for this dataset.\n",
        "#\n",
        "#   M8 therefore builds on M5's winning configuration (BatchNorm + Flatten +\n",
        "#   light augmentation) and introduces one structural change: two convolutional\n",
        "#   layers per block instead of one (VGG-style double conv).\n",
        "#\n",
        "#   Rationale for double conv per block:\n",
        "#   Two stacked 3Г—3 convolutions have the same effective receptive field as a\n",
        "#   single 5Г—5 convolution but with fewer parameters and an extra non-linearity\n",
        "#   between them. The additional non-linearity makes the feature detectors more\n",
        "#   expressive вҖ” rather than one linear filter followed by ReLU, the network\n",
        "#   applies two successive transformations before pooling. This allows each\n",
        "#   block to capture richer combinations of low-level features before\n",
        "#   downsampling discards spatial detail.\n",
        "#   Block 1: detects edges + simple textures more thoroughly\n",
        "#   Block 2: combines textures into surface patterns (corrugation, smoothness)\n",
        "#   Block 3: assembles patterns into object-level representations\n",
        "#   Filter progression 32 вҶ’ 64 вҶ’ 128 is retained from M5.\n",
        "#   BatchNorm after every conv (6 total) stabilises the deeper stack.\n",
        "#   Flatten + Dense(256) head retained вҖ” confirmed stronger than GAP on M6.\n",
        "\n",
        "def build_m8():\n",
        "    model = Sequential([\n",
        "        # Block 1 вҖ” 32 filters Г— 2\n",
        "        Conv2D(32, (3,3), padding='same',\n",
        "               input_shape=(img_rows, img_cols, channels)),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        Conv2D(32, (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 2 вҖ” 64 filters Г— 2\n",
        "        Conv2D(64, (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        Conv2D(64, (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        # Block 3 вҖ” 128 filters Г— 2\n",
        "        Conv2D(128, (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        Conv2D(128, (3,3), padding='same'),\n",
        "        BatchNormalization(),\n",
        "        tf.keras.layers.Activation('relu'),\n",
        "        MaxPooling2D(2, 2),\n",
        "\n",
        "        Flatten(),\n",
        "        Dense(256, activation='relu'),\n",
        "        Dense(num_classes, activation='softmax')\n",
        "    ], name='M8_VGG_Style_CNN')\n",
        "    model.summary()\n",
        "    return model\n",
        "\n",
        "m8 = build_m8()\n",
        "\n",
        "m8.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=1e-3),\n",
        "           loss='sparse_categorical_crossentropy',\n",
        "           metrics=['accuracy'])\n",
        "\n",
        "# Light augmentation вҖ” confirmed correct policy from M5 vs M7 comparison\n",
        "history_m8 = m8.fit(\n",
        "    datagen_light.flow(X_train, y_train, batch_size=BATCH_SIZE),\n",
        "    epochs=40,\n",
        "    validation_data=(X_test, y_test),\n",
        "    callbacks=get_callbacks(patience_es=12, patience_lr=6),\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "plot_history(history_m8, 'M8 вҖ” Deep VGG-style CNN')\n",
        "results_m8 = evaluate_model(m8, X_test, y_test, 'M8 вҖ” Deep VGG-style CNN')"
      ],
